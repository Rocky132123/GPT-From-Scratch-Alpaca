class Tokenizer:
    def __init__(self, sp):
        self.sp = sp
        self.vocab_size = sp.get_piece_size()

    def encode(self, text):
        return self.sp.encode(text, out_type=int)

    def decode(self, ids):
        return self.sp.decode(ids)

tokenizer = Tokenizer(sp)

